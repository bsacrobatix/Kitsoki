{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "shell_repair",
  "type": "object",
  "required": ["command", "why"],
  "additionalProperties": false,
  "properties": {
    "command": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\n]+$"
    },
    "why": {
      "type": "string",
      "maxLength": 280
    }
  }
}
