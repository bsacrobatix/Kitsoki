{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "diagnose_artifact",
  "description": "CI failure diagnosis. Produced by `diagnose_executing` and judged at `diagnose_awaiting_reply`. Accept advances to re_push.",
  "type":    "object",
  "required": ["summary_title", "summary_markdown", "root_cause", "fix_description"],
  "properties": {
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 40 },
    "root_cause":       { "type": "string", "minLength": 10 },
    "fix_description":  { "type": "string", "minLength": 10 },
    "affected_files":   {
      "type": "array",
      "items": { "type": "string" }
    },
    "failing_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence":  { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "reasoning":   { "type": "string" }
  },
  "additionalProperties": true
}
