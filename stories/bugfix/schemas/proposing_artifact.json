{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "proposing_artifact",
  "description": "Artifact produced by the proposing room: the proposed fix, root-cause analysis, and confidence.",
  "type":    "object",
  "required": ["summary_title", "summary_markdown", "fix_description", "root_cause", "affected_files", "confidence", "reasoning"],
  "properties": {
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 200, "description": "Markdown view delivered to the transport." },
    "fix_description":  { "type": "string", "minLength": 40, "description": "Concrete description of what the fix does." },
    "root_cause":       { "type": "string", "minLength": 40, "description": "Root-cause analysis." },
    "affected_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "pattern": "^[^/].+\\..+$" },
          {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string", "pattern": "^[^/].+\\..+$" }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "reasoning":  { "type": "string", "minLength": 80, "description": "Reasoning behind the proposed fix." },
    "alternative_approaches": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          { "type": "object", "additionalProperties": true }
        ]
      }
    },
    "external_dependencies": { "type": "array", "items": { "type": "string" } },
    "implementation_plan": {
      "description": "Optional bounded, dependency-ordered work items for the codeact_decomposed treatment. Legacy proposals omit this field.",
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "depends_on", "objective", "evidence_refs", "read_paths", "write_paths", "invariants", "acceptance_commands", "expected_artifacts", "max_steps", "fallback_reason_allowlist"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,31}$" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "objective": { "type": "string", "minLength": 8 },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "read_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "write_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "invariants": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "acceptance_commands": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "expected_artifacts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "max_steps": { "type": "integer", "minimum": 1, "maximum": 5 },
          "fallback_reason_allowlist": {
            "type": "array",
            "items": { "type": "string", "enum": ["capability_missing", "task_not_decomposable"] },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
