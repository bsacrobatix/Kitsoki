{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "task_summary_artifact",
  "description": "Normalised understanding of the task ticket. Produced by review_task_executing; judged at review_task_awaiting_reply.",
  "type":    "object",
  "required": ["summary_title", "summary_markdown", "scope", "acceptance_criteria"],
  "properties": {
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 40, "description": "Markdown view delivered to the transport." },
    "scope":            { "type": "string", "minLength": 10, "description": "What is in / out of scope." },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 4 }
    },
    "involved_components": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "name":   { "type": "string" },
              "reason": { "type": "string" }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "estimated_loc": { "type": "integer", "minimum": 0 },
    "risk":          { "type": "string", "enum": ["low", "medium", "high"] }
  },
  "additionalProperties": true
}
