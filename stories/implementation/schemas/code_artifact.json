{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "code_artifact",
  "description": "Concrete description of the code change that lands the task. Produced by write_code_executing; judged at write_code_awaiting_reply.",
  "type":    "object",
  "required": ["summary_title", "summary_markdown", "affected_files", "confidence", "reasoning"],
  "properties": {
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 40, "description": "Markdown view delivered to the transport." },
    "affected_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "pattern": "^[^/].+\\..+$" },
          {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path":   { "type": "string", "pattern": "^[^/].+\\..+$" },
              "change": { "type": "string" }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "reasoning":  { "type": "string", "minLength": 20 },
    "patch_summary": { "type": "string", "description": "One-paragraph summary of what the diff does." },
    "tests_planned": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
