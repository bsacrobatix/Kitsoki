{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "review_artifact",
  "description": "LLM code-review outcome. Produced by review_executing; judged at review_awaiting_reply.",
  "type":    "object",
  "required": ["summary_title", "summary_markdown", "status"],
  "properties": {
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 20 },
    "status":           { "type": "string", "enum": ["approved", "changes_requested", "blocked"] },
    "nits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file":        { "type": "string" },
          "line":        { "type": ["integer", "string"] },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file":        { "type": "string" },
          "description": { "type": "string" },
          "severity":    { "type": "string", "enum": ["blocker", "major", "minor"] }
        },
        "additionalProperties": true
      }
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
  },
  "additionalProperties": true
}
