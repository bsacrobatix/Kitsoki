{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "idea_implementation_classification",
  "type": "object",
  "additionalProperties": false,
  "required": ["route", "confidence", "reason", "questions"],
  "properties": {
    "route": {
      "type": "string",
      "enum": ["bug", "feature", "needs_human"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "brief": {
      "type": "string"
    },
    "gate_command": {
      "type": "string"
    },
    "ticket_id": {
      "type": "string"
    }
  }
}
