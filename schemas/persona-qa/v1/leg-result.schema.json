{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kitsoki.dev/schemas/persona-qa/v1/leg-result.schema.json",
  "title": "Persona QA Transport Leg Result",
  "type": "object",
  "required": ["scenario", "transport", "driver_status", "verdict", "verdict_summary"],
  "additionalProperties": true,
  "properties": {
    "scenario": { "type": "string" },
    "transport": { "type": "string", "enum": ["tui", "web", "vscode", "cli"] },
    "driver_status": { "type": "string" },
    "verdict": { "type": "string", "enum": ["pass", "fail", "degraded-evidence", "blocked", "unjudged"] },
    "verdict_summary": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_level": { "type": "string" },
    "transport_evidence_contract": { "type": "object", "additionalProperties": true }
  }
}
