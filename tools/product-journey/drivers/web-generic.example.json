{
  "id": "example-web-app",
  "label": "Example downstream web app",
  "app_kind": "web",
  "launch": {
    "command": "npm run dev -- --host 127.0.0.1",
    "cwd": ".",
    "ready": {"http": "http://127.0.0.1:5173/", "timeout_s": 60},
    "teardown": "git checkout -- data/dev-state.json"
  },
  "capabilities": {
    "visual.open": ["mcp__browser__navigate"],
    "visual.observe": ["mcp__browser__observe", "mcp__browser__screenshot"],
    "visual.act": ["mcp__browser__click", "mcp__browser__fill", "mcp__browser__press"],
    "session.open": ["mcp__browser__navigate"],
    "session.status": ["mcp__browser__observe"],
    "session.submit": ["mcp__browser__press", "mcp__browser__click"],
    "session.drive": ["mcp__browser__click", "mcp__browser__fill", "mcp__browser__press"],
    "session.inspect": ["mcp__browser__observe", "mcp__browser__console", "mcp__browser__network"],
    "session.trace": ["mcp__browser__console", "mcp__browser__network"],
    "render.tui": ["mcp__browser__screenshot"]
  },
  "affordances": {
    "open-dashboard": "[data-testid=dashboard-open]",
    "search": "[data-testid=global-search]",
    "save": "[data-testid=save]"
  },
  "evidence_contract": {
    "web": {"primary_tool": "mcp__browser__screenshot", "evidence_kind": "browser_screenshot", "level": "frame-level"}
  },
  "oracles": [
    {"id": "app-checks", "command": "scripts/checks.sh", "expect_exit": 0}
  ]
}
