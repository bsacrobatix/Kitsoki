{
  "_comment": "Kitsoki concept pitch — silent ~80s cut. Sells the workflow-inside-existing-systems framing.",

  "meta": {
    "mode":   "pitch",
    "title":  "Kitsoki",
    "ticket": "",
    "phase":  "demo",
    "resolution": { "width": 1920, "height": 1080 }
  },

  "scenes": [

    {
      "type": "title",
      "title": "Kitsoki",
      "subtitle": "A conversational workflow engine with deterministic flow"
    },

    {
      "type": "narrative",
      "eyebrow": "The setting",
      "body": "You have a workflow. People drive it by chatting where the work already lives.",
      "lede": "A GitHub issue. A Jira ticket. A Slack thread. A CRM record.",
      "hold": 165
    },

    {
      "type": "diagram-svg",
      "title": "One workflow, many surfaces",
      "panels": [
        {
          "label": "",
          "viewBox": "0 0 880 460",
          "nodes": [
            {
              "id": "wf", "label": "Kitsoki", "sub": "state machine",
              "x": 320, "y": 180, "w": 240, "h": 110, "style": "primary"
            },
            {
              "id": "gh",   "label": "GitHub issue",   "sub": "comments",
              "x": 300, "y":  20, "w": 280, "h": 120
            },
            {
              "id": "jira", "label": "Jira ticket",    "sub": "comments",
              "x":  20, "y": 180, "w": 260, "h": 110
            },
            {
              "id": "cli",  "label": "Local TUI",      "sub": "kitsoki run",
              "x": 600, "y": 180, "w": 260, "h": 110
            },
            {
              "id": "slack","label": "Slack thread",   "sub": "replies",
              "x": 300, "y": 340, "w": 280, "h": 120
            }
          ],
          "edges": [
            { "from": "gh",   "to": "wf" },
            { "from": "jira", "to": "wf" },
            { "from": "cli",  "to": "wf" },
            { "from": "slack","to": "wf" }
          ]
        }
      ],
      "caption": "One YAML state machine drives every surface — the same flow runs in a terminal and in a real ticket thread.",
      "hold": 210
    },

    {
      "type": "narrative",
      "eyebrow": "The problem",
      "body": "Building this chatbot is harder than it looks.",
      "lede": "Pure LLM agents drift, can't be tested, and break unpredictably. Hand-coded state machines can't parse free text or evolve.",
      "hold": 165
    },

    {
      "type": "diagram-svg",
      "title": "Control inversion",
      "panels": [
        {
          "label": "Typical agent",
          "viewBox": "0 0 400 360",
          "nodes": [
            {
              "id": "llm", "label": "LLM", "sub": "plan · reason · decide",
              "x": 70, "y": 50, "w": 260, "h": 90, "style": "primary"
            },
            {
              "id": "rt", "label": "runtime", "sub": "execute",
              "x": 70, "y": 240, "w": 260, "h": 90
            }
          ],
          "edges": [
            { "from": "llm", "to": "rt", "label": "calls" }
          ],
          "caption": "LLM holds the plan; runtime executes."
        },
        {
          "label": "Kitsoki",
          "viewBox": "0 0 400 360",
          "nodes": [
            {
              "id": "rt", "label": "runtime", "sub": "state machine",
              "x": 70, "y": 50, "w": 260, "h": 90, "style": "primary"
            },
            {
              "id": "llm", "label": "LLM", "sub": "narrow sub-task",
              "x": 70, "y": 240, "w": 260, "h": 90, "style": "secondary"
            }
          ],
          "edges": [
            { "from": "rt",  "to": "llm", "label": "resolve this", "side": "left"  },
            { "from": "llm", "to": "rt",  "label": "typed intent", "side": "right" }
          ],
          "caption": "Runtime holds the plan; LLM is called as a sub-task."
        }
      ],
      "caption": "The arrow that matters is the LLM's return arrow — a typed intent, not a free-form action.",
      "hold": 210
    },

    {
      "type": "diagram-svg",
      "title": "Phases, not prompts",
      "panels": [
        {
          "label": "One prompt",
          "viewBox": "0 0 600 580",
          "nodes": [
            {
              "id": "prompt", "label": "PROMPT",
              "lines": [
                "validate the bug,",
                "then fix it,",
                "then make sure",
                "you did a good job."
              ],
              "x": 80, "y": 30, "w": 440, "h": 230
            },
            {
              "id": "agent", "label": "agent", "sub": "opus",
              "lines": [
                "tools: shell + git + repo",
                "domain: entire codebase"
              ],
              "x": 140, "y": 340, "w": 320, "h": 200, "style": "primary"
            }
          ],
          "edges": [
            { "from": "prompt", "to": "agent" }
          ]
        },
        {
          "label": "Kitsoki bug-fix",
          "viewBox": "0 0 620 580",
          "nodes": [
            {
              "id": "reproduce", "label": "reproduce", "sub": "haiku",
              "lines": ["read-only ticket+repo", "→ report + fixture test"],
              "x": 110, "y": 10, "w": 400, "h": 120
            },
            {
              "id": "plan", "label": "plan", "sub": "opus",
              "lines": ["→ plan (approval)"],
              "x": 110, "y": 170, "w": 400, "h": 100
            },
            {
              "id": "implement", "label": "implement", "sub": "sonnet",
              "lines": ["worktree write only", "→ commit"],
              "x": 110, "y": 310, "w": 400, "h": 120
            },
            {
              "id": "review", "label": "review", "sub": "opus",
              "lines": ["read-only"],
              "x": 110, "y": 470, "w": 400, "h": 100
            }
          ],
          "edges": [
            { "from": "reproduce", "to": "plan",      "gate": "test fails" },
            { "from": "plan",      "to": "implement", "gate": "approved" },
            { "from": "implement", "to": "review",    "gate": "tests pass" }
          ]
        }
      ],
      "caption": "Each phase has its own model, its own permissions, and a typed output — reproduced as a structured report plus a fixture test before any fix gets planned.",
      "hold": 300
    },

    {
      "type": "trace",
      "title": "Deterministic first",
      "turns": [
        {
          "user":   "kick off the next bug",
          "layers": [
            { "name": "synonym", "result": "MISS" },
            { "name": "slot",    "result": "MISS" },
            { "name": "LLM",     "result": "HIT",  "ms": 240 }
          ],
          "intent": "pickup_bug"
        },
        {
          "user":   "review",
          "layers": [
            { "name": "synonym", "result": "HIT" }
          ],
          "intent": "review_bug",
          "no_llm": true
        }
      ],
      "caption": "Synonyms and slot templates handle the common cases. The LLM is only called when they miss.",
      "hold": 210
    },

    {
      "type": "narrative",
      "eyebrow": "The dev loop",
      "body": "Author locally. Replay. Deploy.",
      "lede": "Edit the YAML. Test without an LLM call. Attach to GitHub Issues or Jira with one config change.",
      "hold": 165
    },

    {
      "type": "thread",
      "title": "Driven from where work lives",
      "panels": [
        {
          "system": "jira",
          "ref":    "PLTFRM-89507",
          "stage":  "refine",
          "messages": [
            {
              "author": "alice", "role": "dev",
              "body":   "Also reject service-account JWTs. They shouldn't reach this route."
            },
            {
              "author": "kitsoki", "role": "bot",
              "body":   "Plan updated:\n• added negative test for service-account JWT\n• tightened middleware match"
            }
          ]
        },
        {
          "system": "bitbucket",
          "ref":    "PR-481",
          "stage":  "review",
          "messages": [
            {
              "author": "alice", "role": "dev",
              "body":   "use a ternary here"
            },
            {
              "author": "kitsoki", "role": "bot",
              "body":   "Acknowledged. Pushing fix…\n\n✓ pushed  a3f8d2c · refactor(auth): use ternary in service-account check"
            }
          ]
        }
      ],
      "caption": "No local checkout. No \"kitsoki run\". The state machine runs in CI; comments are the surface.",
      "hold": 270
    },

    {
      "type": "stat",
      "value":  "78%",
      "label":  "of turns route deterministically — without calling the LLM.",
      "detail": "Measured across the cloak, oregon-trail and dev-story stories.",
      "hold":   150
    },

    {
      "type": "thread",
      "title": "Improves with use",
      "panels": [
        {
          "system": "jira",
          "ref":    "PLTFRM-89507",
          "stage":  "trace",
          "messages": [
            {
              "author": "kitsoki", "role": "bot",
              "body":   "Test-review converted from LLM call → deterministic script.\n\nTrace showed 47 identical calls; replaced with a 12-line script."
            }
          ]
        },
        {
          "system": "jira",
          "ref":    "PLTFRM-89507",
          "stage":  "feedback",
          "messages": [
            {
              "author": "alice", "role": "dev",
              "body":   "feedback for kitsoki — you're being way too verbose in the comments"
            },
            {
              "author": "kitsoki", "role": "bot",
              "body":   "Acknowledged. Tuning comment verbosity in next deploy."
            }
          ]
        },
        {
          "system": "jira",
          "ref":    "PLTFRM-89507",
          "stage":  "knowledge",
          "messages": [
            {
              "author": "kitsoki", "role": "bot",
              "body":   "Indexed your team's internal tooling and docs:\n• runbook RUN-042 → embedded in the auth-fix prompt\n• stand-validate command → wrapped as a host call"
            }
          ]
        }
      ],
      "caption": "The trace tells the author where the LLM keeps being asked the same question. Each conversion is one diff against the YAML — and the system absorbs your existing tools as it goes.",
      "hold": 300
    },

    {
      "type": "cta",
      "wordmark": "Kitsoki",
      "tagline":  "Predictable by construction. Interpretive where it has to be.",
      "url":      "github.com/cyberfabric/Kitsoki",
      "hold":     180
    }

  ]
}
