# Paired-task arena runtime. It intentionally reuses the broad repo-runtime
# surface because pilot tasks span JS/TS, Go, Python, Rust, and docs repos.
FROM golang:1.25-bookworm

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      bash \
      make \
      build-essential \
      python3 \
      python3-yaml \
      python3-pip \
      jq \
 && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
 && apt-get update \
 && apt-get install -y --no-install-recommends nodejs \
 && corepack enable \
 && corepack prepare pnpm@11.3.0 --activate \
 && npm install -g @openai/codex \
 && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --no-modify-path \
 && ln -s /root/.cargo/bin/cargo /usr/local/bin/cargo \
 && ln -s /root/.cargo/bin/rustup /usr/local/bin/rustup \
 && ln -s /root/.cargo/bin/rustc /usr/local/bin/rustc \
 && rm -rf /root/.rustup/settings.toml

ENV DEBIAN_FRONTEND=noninteractive \
    PATH="/root/.cargo/bin:${PATH}" \
    KITSOKI_ROOT="/workspace/kitsoki" \
    CARGO_HOME="/root/.cargo" \
    CARGO_TARGET_DIR="/workspace/.cache/cargo-target" \
    PNPM_STORE_DIR="/workspace/.cache/pnpm"

WORKDIR /workspace
