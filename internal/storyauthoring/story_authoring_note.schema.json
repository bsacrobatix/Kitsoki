{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "string"
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "string"
    },
    "remaining_work": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
